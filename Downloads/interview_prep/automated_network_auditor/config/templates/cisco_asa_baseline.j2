! ============================================================
! Cisco ASA Baseline Configuration
! Device: {{ device.name }}  |  Host: {{ device.host }}
! Role: {{ device.role }}    |  Location: {{ device.location }}
! Generated: {{ timestamp }}
! ============================================================

hostname {{ device.name }}
domain-name {{ domain | default('corp.local') }}

! ── AAA ──────────────────────────────────────────────────
aaa-server LOCAL protocol local
aaa authentication ssh console LOCAL
aaa authentication enable console LOCAL
aaa authorization command LOCAL

username admin password {{ admin_secret | default('CHANGE_ME') }} privilege 15

! ── SSH ──────────────────────────────────────────────────
crypto key generate rsa modulus 2048
ssh version 2
ssh timeout 60
{% for mgmt_net in mgmt_networks | default(['10.0.0.0 255.255.255.0']) %}
ssh {{ mgmt_net }} management
{% endfor %}

! ── NTP ──────────────────────────────────────────────────
{% for ntp_server in ntp_servers | default(['10.0.0.100']) %}
ntp server {{ ntp_server }}
{% endfor %}

! ── Logging ──────────────────────────────────────────────
logging enable
logging buffered informational
logging trap informational
logging timestamp
{% if syslog_server is defined %}
logging host management {{ syslog_server }}
{% endif %}

! ── Banner ───────────────────────────────────────────────
banner motd ^
***************************************************************************
*  AUTHORIZED ACCESS ONLY — {{ org_name | default('CORP') }} PROPERTY     *
*  Unauthorized access is strictly prohibited.                             *
*  All sessions are monitored and logged.                                  *
***************************************************************************
^

! ── Disable Unnecessary Services ─────────────────────────
no snmp-server community public
no snmp-server community private
http server enable
no telnet 0.0.0.0 0.0.0.0 management

end
